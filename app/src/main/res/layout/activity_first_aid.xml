<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2FFF2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                app:tint="#1C8A2F" />

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Aid Assistant"
                android:textColor="#1C8A2F"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Buttons group 1 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnCut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cut or Scratch"
                android:padding="10dp"
                android:backgroundTint="#32a852"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnBurn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Burn"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#32a852"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnHeadache"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Headache"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#32a852"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Buttons group 2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnSprain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sprain"
                android:padding="10dp"
                android:backgroundTint="#32a852"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnNosebleed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nosebleed"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#32a852"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Result Box -->
        <TextView
            android:id="@+id/txtResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="18dp"
            android:layout_marginTop="25dp"
            android:textSize="17sp"
            android:textColor="#000"
            android:background="#DFFFE2"
            android:text="Select a condition to view first aid steps"
            android:gravity="center"
            android:elevation="4dp" />

        <!-- Emergency Contacts -->
        <TextView
            android:id="@+id/txtEmergency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Contacts"
            android:layout_marginTop="25dp"
            android:textStyle="bold"
            android:textColor="#B50808"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnAmbulance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚑 Ambulance"
                android:padding="10dp"
                android:backgroundTint="#FF0000"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnPolice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👮 Police"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#0040FF"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnFire"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 Fire"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#FF7A00"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- SOS GPS Button -->
        <Button
            android:id="@+id/btnSOS"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚨 SOS — Send GPS Location"
            android:layout_marginTop="22dp"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C50000" />

    </LinearLayout>
</ScrollView>
